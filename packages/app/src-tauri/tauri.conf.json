{
  "$schema": "https://raw.githubusercontent.com/niclas-niclas/tauri-apps--tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Nori",
  "version": "0.1.0",
  "identifier": "com.nori.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "externalBin": ["binaries/nori-server"]
  },
  "app": {
    "windows": [
      {
        "title": "Nori",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
