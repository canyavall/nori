{
  "type": "api_call",
  "what": "Fetch skill list from GET /api/project/claude/skills",
  "why": "Populates the skills page with all project skills",
  "where": {
    "component": "features/project/project-claude-skills/SkillsSection.hook.ts"
  },
  "contract": {
    "endpoint": "GET /api/project/claude/skills",
    "request_type": "{ projectPath: string (query param) }",
    "response_type": "@nori/shared:ClaudeSkillListResponse",
    "sse_events": []
  },
  "transitions": {
    "on_result": "02-show-skills-list",
    "on_error": "show error state"
  },
  "success_handling": {
    "criteria": "API returns skill array",
    "transition": "02-show-skills-list"
  },
  "error_handling": [
    {
      "scenario": "API request fails",
      "criteria": "Network error or non-2xx response",
      "action": "Show error message in the skills section",
      "severity": "error",
      "recoverable": true
    }
  ],
  "decisions": []
}
